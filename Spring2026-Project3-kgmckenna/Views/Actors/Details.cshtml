@model Spring2026_Project3_kgmckenna.ViewModels.ActorDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

@if (Model.Actor.Photo != null)
{
    <img src="data:image/*;base64,@Convert.ToBase64String(Model.Actor.Photo)"
         alt="Actor Photo"
         style="max-width:300px; max-height:450px;" />
}
else
{
    <p>No photo uploaded.</p>
}

<h1>Details</h1>

<div>
    <h4>Actor</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Gender)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.Gender)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.Age)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.Age)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Actor.ImdbLink)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Actor.ImdbLink)
        </dd>
    </dl>
    <h3>Movies with this Actor</h3>

    @if (Model.MovieTitles.Any())
    {
        <ul>
            @foreach (var movie in Model.MovieTitles)
            {
                <li>@movie</li>
            }
        </ul>
    }
    else
    {
        <p>No movies linked to this actor yet.</p>
    }

    <h3>Overall Sentiment: @Model.OverallSentiment</h3>

    <table class="table">
        <thead>
            <tr>
                <th>AI Tweet</th>
                <th>Sentiment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.TweetsWithSentiment)
            {
                <tr>
                    <td>@item.Review</td>
                    <td>@item.Sentiment</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Actor.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
<div class="container">
    <div class="row mb-5">
        <div class="col-md-4 text-center">
            @if (Model.Actor.Photo != null)
            {
                <img src="data:image/*;base64,@Convert.ToBase64String(Model.Actor.Photo)"
                     class="detail-image"
                     alt="Actor Photo" />
            }
            else
            {
                <div class="image-placeholder">No Photo</div>
            }
        </div>

        <div class="col-md-8">
            <div class="detail-card">
                <h1>@Model.Actor.Name</h1>
                <hr />

                <p><strong>Age:</strong> @Model.Actor.Age</p>
                <p><strong>Gender:</strong> @Model.Actor.Gender</p>

                <p>
                    <strong>IMDb:</strong>
                    <a href="@Model.Actor.ImdbLink" target="_blank">View on IMDb</a>
                </p>

                <h4 class="mt-4">Movies</h4>

                @if (Model.MovieTitles.Any())
                {
                    <ul>
                        @foreach (var actor in Model.MovieTitles)
                        {
                            <li>@actor</li>
                        }
                    </ul>
                }
                else
                {
                    <p>No actors linked yet.</p>
                }

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Actor.Id" class="btn btn-primary me-2">Edit</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>

    <div class="detail-card mb-4">
        <h2>AI Tweets</h2>
        <h5 class="text-muted">Overall Sentiment: @Model.OverallSentiment</h5>

        <table class="table table-striped mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Review</th>
                    <th style="width: 150px;">Sentiment</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.TweetsWithSentiment)
                {
                    <tr>
                        <td>@item.Review</td>
                        <td>
                            @if (item.Sentiment == "Positive")
                            {
                                <span class="badge bg-success">Positive</span>
                            }
                            else if (item.Sentiment == "Negative")
                            {
                                <span class="badge bg-danger">Negative</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Neutral</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>